# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (Local Development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dungeon_lair_db
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_SSL=false

# Railway Database (automatically provided by Railway PostgreSQL plugin)
# DATABASE_URL=postgresql://user:password@host:port/database
# Note: Railway sets this automatically - don't set it manually

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random_at_least_32_characters

# CORS Configuration
CORS_ORIGIN=https://dungeonlair.co.za,https://www.dungeonlair.co.za,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
